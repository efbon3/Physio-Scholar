# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep real values out of git, but commit the .env.example
# template so new contributors know what they need to fill in.
.env*
!.env.example

# vercel
.vercel

# Sentry auth/project config (generated by `sentry-cli`)
.sentryclirc

# Service worker bundles produced by @serwist/next at build time.
# Lint and review the source (src/app/sw.ts); the generated artifact is
# regenerated on every build and shouldn't be committed.
/public/sw.js
/public/swe-worker-*.js
/public/workbox-*.js

# typescript
*.tsbuildinfo
next-env.d.ts

# local Claude Code config (per-user)
.claude/

# test artifacts
/playwright-report/
/test-results/
/coverage/

# OS
Thumbs.db
