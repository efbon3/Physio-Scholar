# Copy this file to `.env.local` and fill in values for local development.
# Never commit `.env.local` or any file containing real secrets.
#
# Each section is wired up in a later phase of the build spec. Empty values are
# acceptable for Phase 1 — the app boots without them.

# --- Supabase (Phase 1, auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Phase 4, self-explanation grading) ---
ANTHROPIC_API_KEY=

# --- Transactional email (Phase 1, Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Observability ---
# Sentry — set DSN + ORG + PROJECT to enable error monitoring.
# AUTH_TOKEN is only needed for source-map upload in CI/Vercel.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# PostHog — analytics only fires after the user checks the analytics
# consent box at signup (see src/app/(auth)/signup/actions.ts).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
